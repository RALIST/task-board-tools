.DS_Store

# Compiled CLI binary — built either inside cli/ (`cd cli && go build -o tb .`)
# or from the repo root via go.work (`go build ./cli` writes ./tb due to `module tools/tb`).
/cli/tb
/tb

# Runtime flock target — recreated on every CLI invocation.
board/.board.lock

# tb-gui build artefacts (the gui/.gitignore covers the rest under gui/).
/tb-gui
/gui/tb-gui
/gui/bin
/gui/.task
/gui/frontend/dist
/gui/frontend/node_modules
/gui/frontend/.svelte-kit
/board/.agent-log
/board/.agent-state

# tb-gui claude usage tap (auto-added)
/.claude/settings.local.json
/.claude/tb-gui-statusline.sh
/.claude/tb-gui-usage.json
