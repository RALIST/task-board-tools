.DS_Store

# Compiled CLI binary — built either inside cli/ (`cd cli && go build -o tb .`)
# or from the repo root via go.work (`go build ./cli` writes ./tb due to `module tools/tb`).
/cli/tb
/tb

# Runtime flock target — recreated on every CLI invocation.
board/.board.lock

# Local agent/runtime artifacts. Two layouts coexist:
# - file-form (legacy): board/.agent-state/<ID>.jsonl + board/.agent-logs/<ID>/<run>.log
# - folder-form: board/<status>/<ID>/.agent-state.jsonl + board/<status>/<ID>/.agent-logs/
# Both may contain agent stdout/stderr — treat as sensitive.
/board/.agent-state/
/board/.agent-logs/
/board/**/.agent-state.jsonl
/board/**/.agent-logs/
!/.claude/.gitkeep

# tb-gui build artefacts (the gui/.gitignore covers the rest under gui/).
/tb-gui
/gui/tb-gui
/gui/bin
/gui/.task
/gui/frontend/dist
/gui/frontend/node_modules
/gui/frontend/.svelte-kit

# tb-gui claude usage tap (auto-added)
/.claude/settings.local.json
/.claude/tb-gui-statusline.sh
/.claude/tb-gui-usage.json
